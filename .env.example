# EmailJS credentials — replace ALL placeholders below with your real values.
# Get them from: https://dashboard.emailjs.com
#
# 1. Public Key  → Account → API Keys → Public Key
# 2. Service ID  → Email Services → your service → Service ID (service_xxxxx)
# 3. Template ID → Email Templates → your template → Template ID (template_xxxxx)
#
# After saving, restart: npm run dev

VITE_EMAILJS_PUBLIC_KEY=
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
